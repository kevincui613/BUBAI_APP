generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt      @id @default(autoincrement())
  email        String      @unique @db.VarChar(191)
  passwordHash String      @db.VarChar(255)
  nickname     String      @db.VarChar(50)
  timezone     String      @default("Asia/Shanghai") @db.VarChar(50)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  profile           SocialUserProfile?
  visibilitySetting SocialVisibilitySetting?
  goals             Goal[]
  dailyTasks        DailyTask[]
  aiPlanRecords     AiPlanRecord[]
  sentRequests      Friendship[] @relation("friendship_sender")
  receivedRequests  Friendship[] @relation("friendship_receiver")
  circleMembers     CircleMember[]
  teamPosts         TeamPost[]
  challengeMembers  TeamChallengeMember[]
}

model Goal {
  id          BigInt      @id @default(autoincrement())
  userId      BigInt
  title       String      @db.VarChar(100)
  description String?     @db.VarChar(500)
  targetTotal Int
  unit        String      @db.VarChar(20)
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  status      GoalStatus  @default(active)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user      User      @relation(fields: [userId], references: [id])
  dailyTasks DailyTask[]

  @@index([userId, status])
}

model DailyTask {
  id              BigInt    @id @default(autoincrement())
  userId          BigInt
  goalId          BigInt
  taskDate        DateTime  @db.Date
  title           String    @db.VarChar(120)
  plannedAmount   Int
  completedAmount Int       @default(0)
  isCompleted     Boolean   @default(false)
  completedAt     DateTime?
  note            String?   @db.VarChar(255)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id])
  goal Goal @relation(fields: [goalId], references: [id])

  @@unique([goalId, taskDate])
  @@index([userId, taskDate])
}

model SocialUserProfile {
  id         BigInt   @id @default(autoincrement())
  userId      BigInt   @unique
  bio        String?  @db.VarChar(255)
  goalTag    String?  @db.VarChar(50)
  city       String?  @db.VarChar(50)
  streakDays Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Friendship {
  id           BigInt           @id @default(autoincrement())
  userId       BigInt
  friendUserId BigInt
  status       FriendshipStatus @default(pending)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  user       User @relation("friendship_sender", fields: [userId], references: [id])
  friendUser User @relation("friendship_receiver", fields: [friendUserId], references: [id])

  @@unique([userId, friendUserId])
  @@index([friendUserId, status])
}

model SocialVisibilitySetting {
  id        BigInt     @id @default(autoincrement())
  userId    BigInt     @unique
  visibility Visibility @default(friends)
  updatedAt DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model Circle {
  id          BigInt        @id @default(autoincrement())
  name        String        @db.VarChar(100)
  category    String        @db.VarChar(50)
  intro       String        @db.VarChar(255)
  memberCount Int           @default(0)
  createdAt   DateTime      @default(now())

  members CircleMember[]
}

model CircleMember {
  id       BigInt   @id @default(autoincrement())
  circleId BigInt
  userId   BigInt
  joinedAt DateTime @default(now())

  circle Circle @relation(fields: [circleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([circleId, userId])
}

model TeamPost {
  id           BigInt   @id @default(autoincrement())
  userId       BigInt
  title        String   @db.VarChar(120)
  goal         String   @db.VarChar(255)
  headcount    Int
  currentCount Int      @default(1)
  contact      String   @db.VarChar(100)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model TeamChallenge {
  id        BigInt   @id @default(autoincrement())
  title     String   @db.VarChar(120)
  target    String   @db.VarChar(255)
  progress  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members TeamChallengeMember[]
}

model TeamChallengeMember {
  id          BigInt @id @default(autoincrement())
  challengeId BigInt
  userId      BigInt
  rank        Int    @default(1)

  challenge TeamChallenge @relation(fields: [challengeId], references: [id])
  user      User          @relation(fields: [userId], references: [id])

  @@unique([challengeId, userId])
}

model AiPlanRecord {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt
  goalTitle   String   @db.VarChar(120)
  periodDays  Int
  dailyMinutes Int
  level       String   @db.VarChar(20)
  summary     String   @db.VarChar(500)
  rawResultJson Json
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

enum GoalStatus {
  active
  completed
  archived
}

enum FriendshipStatus {
  pending
  accepted
  rejected
  blocked
}

enum Visibility {
  public
  friends
  private
}
